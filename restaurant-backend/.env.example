# ============================================
# CONFIGURACIÓN DEL SERVIDOR
# ============================================
PORT=3000
NODE_ENV=development
# En producción usar: NODE_ENV=production

# ============================================
# BASE DE DATOS MONGODB
# ============================================
# Desarrollo (MongoDB local)
MONGODB_URI=mongodb://127.0.0.1:27017/restaurant-pm

# Producción (MongoDB Atlas) - REEMPLAZAR CON TUS CREDENCIALES
# MONGODB_URI=mongodb+srv://USUARIO:PASSWORD@cluster.mongodb.net/restaurant-pm?retryWrites=true&w=majority

# ============================================
# AUTENTICACIÓN JWT (OBLIGATORIO)
# ============================================
# IMPORTANTE: Genera una clave secreta fuerte de 64+ caracteres
# Puedes usar: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CAMBIAR_POR_UNA_CLAVE_SECRETA_MUY_LARGA_DE_64_CARACTERES_MINIMO

# Duración del token (formato: 1h, 24h, 7d, etc.)
JWT_EXPIRATION=24h

# ============================================
# CORS - ORIGENES PERMITIDOS
# ============================================
# Separar múltiples orígenes con comas
# En desarrollo:
ALLOWED_ORIGINS=http://localhost:3001

# En producción:
# ALLOWED_ORIGINS=https://tudominio.com,https://admin.tudominio.com

# ============================================
# SRI ECUADOR - FACTURACIÓN ELECTRÓNICA
# ============================================
# Ambiente: 1 = Pruebas, 2 = Producción
SRI_ENV=1

# Certificado de Firma Electrónica (.p12)
# Opción 1: Ruta al archivo (desarrollo local)
# SRI_SIGNATURE_PATH=src/secrets/firma.p12

# Opción 2: Certificado en Base64 (RECOMENDADO para producción/cloud)
# Convertir .p12 a Base64: cat firma.p12 | base64 -w 0
SRI_SIGNATURE_BASE64=TU_CERTIFICADO_EN_BASE64

# Contraseña del certificado
SRI_SIGNATURE_PASSWORD=TU_PASSWORD_DEL_CERTIFICADO

# ============================================
# DATOS DEL NEGOCIO
# ============================================
BUSINESS_NAME=Nombre Legal del Negocio
COMMERCIAL_NAME=Nombre Comercial
RUC=1234567890001
DIR_MATRIZ=Direccion de la Matriz
DIR_ESTABLECIMIENTO=Direccion del Establecimiento

# Códigos SRI (3 dígitos cada uno)
ESTAB=001
PTO_EMI=001

# ============================================
# EMAIL - SERVICIO DE ENVÍO
# ============================================
# Usando Resend (recomendado)
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXX
SMTP_FROM=facturacion@tudominio.com
TEST_EMAIL=tu_email@ejemplo.com
BUSINESS_LOGO_URL=https://tudominio.com/logo.png

# ============================================
# CREDENCIALES SEED (solo desarrollo)
# ============================================
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=admin123
SEED_WAITER_USERNAME=mesero
SEED_WAITER_PASSWORD=mesero123
SEED_CHEF_USERNAME=cocinero
SEED_CHEF_PASSWORD=cocinero123

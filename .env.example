# ============================================
# Configuración Docker Compose - Restaurant PM
# ============================================
# Copia este archivo como .env y configura tus valores

# ============================================
# MongoDB
# ============================================
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=changeme123

# ============================================
# Backend - Autenticación
# ============================================
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_EXPIRATION=24h
MASTER_ENCRYPTION_KEY=your-32-char-encryption-key-here

# ============================================
# Backend - CORS
# ============================================
ALLOWED_ORIGINS=http://localhost,http://localhost:80

# ============================================
# Backend - SRI (Sistema de Rentas Internas Ecuador)
# ============================================
SRI_ENV=1
# 1 = Pruebas, 2 = Producción
SRI_SIGNATURE_BASE64=your-base64-signature
SRI_SIGNATURE_PASSWORD=your-signature-password
BUSINESS_NAME=PICANTERIA MIRAFLORES
COMMERCIAL_NAME=Picantería Miraflores
RUC=1234567890001
DIR_MATRIZ=Dirección de la matriz
DIR_ESTABLECIMIENTO=Dirección del establecimiento
ESTAB=001
PTO_EMI=001

# ============================================
# Backend - Email (Resend)
# ============================================
RESEND_API_KEY=re_your_resend_api_key_here
SMTP_FROM=noreply@yourdomain.com
TEST_EMAIL=test@example.com
BUSINESS_LOGO_URL=https://yourdomain.com/logo.png

# ============================================
# Backend - WhatsApp
# ============================================
WHATSAPP_ENABLED=true
# true = habilita WhatsApp Web.js con Chromium
# false = deshabilita WhatsApp (servidor funciona sin él)

# ============================================
# Frontend
# ============================================
VITE_API_URL=http://localhost:3000/api

# ============================================
# Variables de Produccion - Restaurant PM
# Copiar a .env y completar valores reales
# ============================================

# --- MongoDB ---
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=TU_PASSWORD_SEGURA_AQUI

# --- JWT ---
JWT_SECRET=tu_jwt_secret_muy_largo_y_seguro_aqui_min_32_chars
JWT_EXPIRATION=24h

# --- CORS (tu frontend en Vercel) ---
ALLOWED_ORIGINS=https://tu-app.vercel.app,https://picanteriamiraflores.com

# --- WhatsApp ---
WHATSAPP_ENABLED=true

# --- SRI Ecuador ---
SRI_ENV=1
SRI_SIGNATURE_BASE64=
SRI_SIGNATURE_PASSWORD=

# --- Datos del Negocio ---
BUSINESS_NAME=
COMMERCIAL_NAME=
RUC=
DIR_MATRIZ=
DIR_ESTABLECIMIENTO=
ESTAB=001
PTO_EMI=001

# --- Email (Resend) ---
RESEND_API_KEY=
SMTP_FROM=
TEST_EMAIL=
